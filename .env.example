# Salin file ini menjadi .env dan isi dengan nilai sebenarnya
# cp .env.example .env

# === WAJIB ===
# API key dari OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# === TELEGRAM (opsional tapi disarankan) ===
# Token bot dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Chat ID kamu — kirim pesan ke @userinfobot untuk tahu ID kamu
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# === OPSIONAL ===
# Model LLM yang dipakai via OpenRouter (default: DeepSeek V3)
# Alternatif murah: openai/gpt-4o-mini
LLM_MODEL=deepseek/deepseek-chat

# Folder output JSON (default: output/)
OUTPUT_DIR=output
